# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit it.

# === Picnic ===
# Used for first login + 2FA. After successful 2FA, a session token is stored
# on disk (see PICNIC_SESSION_FILE) and credentials are no longer used.
PICNIC_USERNAME=
PICNIC_PASSWORD=
PICNIC_COUNTRY_CODE=NL
PICNIC_SESSION_FILE=./data/picnic-session.json

# === Anthropic API ===
# Separate from any Claude Pro subscription — get a key at console.anthropic.com.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Daily spend ceiling in EUR. When exceeded, the bot stops calling Claude
# until manually resumed via /start or until UTC midnight.
DAILY_SPEND_LIMIT_EUR=2.00

# === Telegram ===
# Get a token from @BotFather. Restrict the bot to a single group chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# === Runtime ===
# `development` enables verbose logging; `production` is quieter.
NODE_ENV=development

# When `true`, the agent runs the full loop but does NOT write to Picnic
# (no addToCart, no commit, no slot reservation). Used for local testing.
DRY_RUN=true

# Where SQLite + profile.md + session files live. Must be writable.
DATA_DIR=./data
