{
  "name": "picnic-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Dutch-speaking Telegram bot that drafts weekly Picnic grocery orders.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "smoke:picnic": "tsx src/picnic/smoke.ts",
    "smoke:memory": "tsx src/memory/smoke.ts",
    "smoke:agent": "tsx src/agent/smoke.ts",
    "start:telegram": "tsx src/telegram/run.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^22.19.19",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.100.1",
    "better-sqlite3": "12.10.0",
    "croner": "10.0.1",
    "dotenv": "17.4.2",
    "picnic-api": "4.4.0",
    "telegraf": "4.16.3"
  }
}
